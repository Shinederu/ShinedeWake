{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@shinederu/auth-core": [
        "../shinederu-auth-core/src/index.ts"
      ],
      "@shinederu/auth-react": [
        "../shinederu-auth-react/src/index.ts"
      ]
    }
  },
  "include": [
    "src",
    "../shinederu-auth-core/src",
    "../shinederu-auth-react/src"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
